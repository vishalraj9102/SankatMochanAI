# Ignore node_modules folder (Frontend)
frontend/node_modules/

# Ignore build output folder for React (Frontend)
frontend/build/

# Ignore package-lock.json file (Frontend)
frontend/package-lock.json

# Ignore environment files (Sensitive information)
.env
.env.local
.env.*.local

# Ignore Python cache and virtualenvs (Backend)
backend/__pycache__/
backend/venv/

# Ignore backend logs or temporary files
backend/*.log
backend/*.pid
backend/*.sqlite3

# Ignore Docker-related files
docker-compose.yml
docker-compose.override.yml
Dockerfile

# Ignore system-specific files (Mac, Windows)
.DS_Store
Thumbs.db

# Ignore IDE or editor-specific files (VSCode, PyCharm, etc.)
.vscode/
.idea/
*.iml

# Ignore other generated files
*.bak
*.swp
*.swo

node_modules
*.log
build
dist
